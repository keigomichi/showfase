# Dart / Flutter
.dart_tool/
.packages
build/
.flutter-plugins
.flutter-plugins-dependencies
.metadata
ephemeral/

# IDE
.idea/
.vscode/
*.iml
*.iws

# macOS
.DS_Store

# Flutter platform-generated caches inside example apps.
packages/*/example/ios/Pods/
packages/*/example/ios/.symlinks/
packages/*/example/android/.gradle/
packages/*/example/macos/Pods/
packages/*/example/macos/Flutter/ephemeral/
packages/*/example/linux/flutter/ephemeral/
packages/*/example/windows/flutter/ephemeral/

# Claude Code local state — belongs to individual contributors.
.claude/.cc-writes/
.claude/settings.local.json

# Defense-in-depth: prevent accidental commits of keys, certs, env files.
*.pem
*.key
*.p12
*.pfx
*.keystore
*.jks
id_rsa*
id_ed25519*
.env
.env.*
.envrc

# Windows OS metadata (macOS `.DS_Store` already covered above).
Thumbs.db
desktop.ini

# Do NOT ignore pubspec.lock — it is used to pin exact dependency versions
# per this project's supply-chain policy.
!pubspec.lock

# Do NOT ignore generated .g.dart files — they are committed on purpose so
# consumers of the example app can inspect them and CI can diff them.
!*.g.dart

# Golden-test failure artifacts (written by flutter_test on mismatch).
**/test/failures/
